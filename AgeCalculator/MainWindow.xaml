<Window x:Class="AgeCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Age Calculator"
        Width="400" Height="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="20">
        <Border x:Name="GlassPanel"
                CornerRadius="25"
                Padding="20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#88FFFFFF" Offset="0"/>
                    <GradientStop Color="#44FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <BlurEffect Radius="25"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <Calendar x:Name="BirthCalendar"
                          DisplayDateEnd="{x:Static System:DateTime.Now}"
                          SelectionMode="SingleDate"
                          SelectedDatesChanged="BirthCalendar_SelectedDatesChanged"/>
                <TextBlock x:Name="AgeText" Text="Select your birthday"
                           HorizontalAlignment="Center" Margin="0,20,0,0"
                           FontSize="18" Opacity="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
